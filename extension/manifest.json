{
  "manifest_version": 3,
  "name": "GamePrice — Fiyat Karşılaştır",
  "version": "1.0.0",
  "description": "Steam mağaza sayfalarında GamePrice fiyat karşılaştırması",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "http://localhost:3000/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "GamePrice",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
