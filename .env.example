# Yerel geliştirme (SQLite — varsayılan)
DATABASE_URL="file:./dev.db"

# Production (Vercel + Neon Postgres) — vercel env pull .env.local
# DATABASE_URL="postgresql://..."

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://gameprice.org

# Google Search Console doğrulama (HTML tag)
# GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxx
# YANDEX_SITE_VERIFICATION=xxxxxxxxxxxxxxxx

# Zorunlu production
# CRON_SECRET=your_random_secret
# ADMIN_SECRET=your_admin_secret

# E-posta (Resend) — fiyat alarmı & haftalık özet
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="GamePrice <noreply@gameprice.org>"

# Web Push: npm run vapid:generate
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@gameprice.org

# Telegram bot (BotFather)
# TELEGRAM_BOT_TOKEN=

# Affiliate (opsiyonel)
# AFFILIATE_GMG_ID=
# AFFILIATE_HUMBLE_ID=
# AFFILIATE_FANATICAL_ID=
# AFFILIATE_GOG_ID=
# AFFILIATE_EPIC_ID=

# Steam Web API (kütüphane sync)
# https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=

# Hata izleme (opsiyonel)
# SENTRY_DSN=

# Meilisearch (opsiyonel hızlı arama — Pro kullanıcılar)
# 1) https://cloud.meilisearch.com → yeni proje oluştur
# 2) Host URL + Admin API Key'i kopyala
# 3) npm run meili:sync  (veya admin panelden "Meilisearch İndeksle")
# MEILISEARCH_HOST=https://ms-xxxxx.meilisearch.io
# MEILISEARCH_API_KEY=
# MEILISEARCH_INDEX=games

# iyzico (Pro abonelik — Türkiye)
# https://merchant.iyzipay.com → Ayarlar → API Anahtarları
# Sandbox: https://sandbox-merchant.iyzipay.com
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Production: https://api.iyzipay.com
# Abonelik plan referans kodları (iyzico panelinden veya npm run iyzico:setup)
# IYZICO_PRICING_PLAN_MONTHLY=
# IYZICO_PRICING_PLAN_YEARLY=
# Webhook URL: https://gameprice.org/api/billing/webhook

# Katalog zenginleştirme (opsiyonel, ücretsiz)
# RAWG_API_KEY=your_rawg_api_key

# Komutlar:
# npm run db:push
# npm run catalog:sync
# npm run deploy
