# Yerel geliştirme (SQLite — varsayılan)
DATABASE_URL="file:./dev.db"

# Production (Vercel + Neon Postgres) — vercel env pull .env.local
# DATABASE_URL="postgresql://..."

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://gameprice-tracker.vercel.app

# Zorunlu production
# CRON_SECRET=your_random_secret
# ADMIN_SECRET=your_admin_secret

# E-posta (Resend) — fiyat alarmı & haftalık özet
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="GamePrice <noreply@yourdomain.com>"

# Web Push: npm run vapid:generate
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@yourdomain.com

# Telegram bot (BotFather)
# TELEGRAM_BOT_TOKEN=

# Affiliate (opsiyonel)
# AFFILIATE_GMG_ID=
# AFFILIATE_HUMBLE_ID=

# Hata izleme (opsiyonel)
# SENTRY_DSN=

# Meilisearch (opsiyonel hızlı arama)
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=
# MEILISEARCH_INDEX=games

# Katalog zenginleştirme (opsiyonel, ücretsiz)
# RAWG_API_KEY=your_rawg_api_key

# Komutlar:
# npm run db:push
# npm run catalog:sync
# npm run deploy
