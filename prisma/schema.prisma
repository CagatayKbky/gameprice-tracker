generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackedGame {
  id               String   @id @default(cuid())
  cheapSharkGameId String   @unique
  title            String
  imageUrl         String?
  steamAppId       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  snapshots PriceSnapshot[]
}

model PriceSnapshot {
  id            String   @id @default(cuid())
  trackedGameId String
  platformId    String
  price         Float
  normalPrice   Float
  discount      Int      @default(0)
  currency      String   @default("USD")
  dealUrl       String?
  isOnSale      Boolean  @default(false)
  recordedAt    DateTime @default(now())

  trackedGame TrackedGame @relation(fields: [trackedGameId], references: [id], onDelete: Cascade)

  @@index([trackedGameId, platformId, recordedAt])
}

model UserProfile {
  id                  String    @id @default(cuid())
  sessionId           String    @unique
  email               String?
  name                String?
  isAdmin             Boolean   @default(false)
  publicProfile       Boolean   @default(true)
  emailNotifications  Boolean   @default(true)
  weeklyDigest        Boolean   @default(true)
  pushNotifications   Boolean   @default(true)
  wishlistDealAlerts  Boolean   @default(true)
  discordWebhook      String?
  telegramChatId      String?
  steamId             String?   @unique
  steamPersona        String?
  steamAvatar         String?
  profileSlug         String?   @unique
  onboardingDone      Boolean   @default(false)
  freeGameNotify      Boolean   @default(true)
  hideOwnedGames      Boolean   @default(true)
  steamLibrarySyncedAt DateTime?
  activeProfileFrame  String    @default("classic")
  activeProfileEffect String    @default("none")
  plan                String    @default("free")
  iyzicoCustomerRef   String?   @unique
  iyzicoSubscriptionRef String? @unique
  planExpiresAt       DateTime?
  referralCode        String?   @unique
  referredBySessionId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([referredBySessionId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  sessionId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model WishlistItem {
  id                 String    @id @default(cuid())
  sessionId          String
  cheapSharkGameId   String
  gameTitle          String
  imageUrl           String?
  lastKnownPrice     Float?
  lastKnownDiscount  Int?
  dealNotifiedAt     DateTime?
  addedAt            DateTime  @default(now())

  @@unique([sessionId, cheapSharkGameId])
  @@index([sessionId])
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  queryNorm String
  sessionId String?
  createdAt DateTime @default(now())

  @@index([queryNorm, createdAt])
  @@index([createdAt])
}

model PriceAlert {
  id               String    @id @default(cuid())
  sessionId        String
  cheapSharkGameId String
  gameTitle        String
  targetPrice      Float
  currentPrice     Float?
  platformId       String?
  isActive         Boolean   @default(true)
  emailNotify      Boolean   @default(true)
  notifiedAt       DateTime?
  triggeredAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([sessionId, isActive])
  @@index([cheapSharkGameId, isActive])
}

model CatalogGame {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  titleNorm    String
  letter       String
  imageUrl     String?
  steamAppId   String?
  rawgId       Int?
  cheapSharkId String?
  platforms    String   @default("[]")
  source       String
  metacritic   Int?
  released     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([titleNorm])
  @@index([letter, titleNorm])
  @@index([title])
}

model CatalogSyncState {
  id         String   @id @default("main")
  steamDone  Boolean  @default(false)
  rawgPage   Int      @default(1)
  rawgDone   Boolean  @default(false)
  totalGames Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model JobLog {
  id         String    @id @default(cuid())
  type       String
  status     String
  meta       String?
  result     String?
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([type, startedAt])
  @@index([startedAt])
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  sessionId String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model SteamOwnedGame {
  id              String   @id @default(cuid())
  sessionId       String
  steamAppId      String
  name            String?
  playtimeMinutes Int      @default(0)
  lastPlayedAt    DateTime?
  syncedAt        DateTime @default(now())

  @@unique([sessionId, steamAppId])
  @@index([sessionId])
}

model FreeGameNotification {
  id        String   @id @default(cuid())
  gameId    String
  platform  String
  title     String
  notifiedAt DateTime @default(now())

  @@unique([gameId, platform])
}

model FriendRequest {
  id            String   @id @default(cuid())
  fromSessionId String
  toSessionId   String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([fromSessionId, toSessionId])
  @@index([toSessionId, status])
  @@index([fromSessionId, status])
}

model UserCosmetic {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  key       String
  source    String   @default("manual")
  createdAt DateTime @default(now())

  @@unique([sessionId, type, key])
  @@index([sessionId, type])
}

model UserNotification {
  id        String    @id @default(cuid())
  sessionId String
  type      String
  title     String
  body      String
  url       String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([sessionId, createdAt])
  @@index([sessionId, readAt])
}
