{
  "name": "gameprice-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prepare-db-provider.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "node scripts/prepare-db-provider.mjs && prisma generate",
    "db:push": "node scripts/prepare-db-provider.mjs && prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "node scripts/prepare-db-provider.mjs && prisma generate",
    "catalog:sync": "npx tsx scripts/run-catalog-sync.ts",
    "vapid:generate": "npx tsx scripts/generate-vapid-keys.ts",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "deploy": "npx vercel deploy --prod --yes"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.64.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "postcss": "^8.5.16",
    "prisma": "^5.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10"
  }
